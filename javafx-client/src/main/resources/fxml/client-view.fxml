<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.csis231.javafxclient.controller.ClientController">

    <top>
        <VBox spacing="10" style="-fx-padding: 15px;">
            <Label text="Client Management" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <HBox spacing="10">
                <Label text="First Name:" minWidth="120"/>
                <TextField fx:id="firstNameField" prefWidth="200"/>

                <Label text="Last Name:" minWidth="120"/>
                <TextField fx:id="lastNameField" prefWidth="200"/>
            </HBox>

            <HBox spacing="10">
                <Label text="Email:" minWidth="120"/>
                <TextField fx:id="emailField" prefWidth="200"/>

                <Label text="Phone:" minWidth="120"/>
                <TextField fx:id="phoneField" prefWidth="200"/>
            </HBox>

            <HBox spacing="10">
                <Label text="Address:" minWidth="120"/>
                <TextField fx:id="addressField" prefWidth="200"/>
            </HBox>

            <HBox spacing="10">
                <Button text="Create" onAction="#createClient"/>
                <Button text="Update" onAction="#updateClient"/>
                <Button text="Delete" onAction="#deleteClient"/>
                <Button text="Refresh" onAction="#loadClients"/>
            </HBox>

            <Label fx:id="statusLabel" text="Ready"/>
        </VBox>
    </top>

    <center>
        <VBox>
            <TableView fx:id="clientTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="firstNameColumn" text="First Name" prefWidth="130"/>
                    <TableColumn fx:id="lastNameColumn" text="Last Name" prefWidth="130"/>
                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="180"/>
                    <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="130"/>
                    <TableColumn fx:id="addressColumn" text="Address" prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>