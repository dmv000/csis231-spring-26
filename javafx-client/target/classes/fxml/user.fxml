<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.csis231.javafxclient.controller.UserController"
          alignment="CENTER" hgap="10" vgap="10">

    <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="usernameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Password:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <PasswordField fx:id="passwordField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Button fx:id="registerButton" text="Register" onAction="#registerUser"
            GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <Button fx:id="loginButton" text="Login" onAction="#loginUser"
            GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    <Button fx:id="clearButton" text="Clear" onAction="#clearForm"
            GridPane.rowIndex="3" GridPane.columnIndex="2"/>

    <Label fx:id="statusLabel" text="Status messages here..."
           GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.columnSpan="3"/>
</GridPane>